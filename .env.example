# ─── Required ────────────────────────────────────────────────────────────────
# Get your key at https://console.anthropic.com
ANTHROPIC_API_KEY=your_api_key_here

# Hugging Face token — required only if you use the "Detect Speakers" feature.
# 1. Create a free account at https://huggingface.co
# 2. Accept the pyannote/speaker-diarization-3.1 model license at
#    https://huggingface.co/pyannote/speaker-diarization-3.1
# 3. Generate a token at https://huggingface.co/settings/tokens
HF_TOKEN=

# ─── Optional ────────────────────────────────────────────────────────────────
# Whisper model size. Options: tiny | base | small | medium | large | large-v2 | large-v3
# Approx sizes: tiny ~75 MB, base ~150 MB, small ~500 MB, medium ~1.5 GB, large ~3 GB
# Smaller = faster but less accurate. "small" is a good default for most machines.
WHISPER_MODEL=small

# Server host (keep 127.0.0.1 for local-only; use 0.0.0.0 to expose on your network)
HOST=127.0.0.1

# Ports
BACKEND_PORT=8000
FRONTEND_PORT=5173
